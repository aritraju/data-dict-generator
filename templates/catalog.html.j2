<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8"/>
<meta name="viewport" content="width=device-width, initial-scale=1.0"/>
<title>Data Catalog — {{ catalog.database_name }}</title>
<style>
  :root {
    --navy: #1B3A6B; --accent: #2E75B6; --light: #F2F4F8;
    --warn: #FFF3CD; --warn-border: #FFC107;
    --green: #D4EDDA; --green-border: #28A745;
    --red: #F8D7DA;
  }
  * { box-sizing: border-box; margin: 0; padding: 0; }
  body { font-family: Arial, sans-serif; font-size: 14px; color: #1A1A2E; background: #F8F9FA; }
  header { background: var(--navy); color: white; padding: 24px 40px; }
  header h1 { font-size: 26px; margin-bottom: 6px; }
  header p  { font-size: 13px; opacity: 0.8; }
  .container { max-width: 1200px; margin: 0 auto; padding: 24px 40px; }
  /* KPI bar */
  .kpi-row { display: flex; gap: 16px; margin-bottom: 28px; }
  .kpi { background: white; border-radius: 8px; padding: 16px 24px; flex: 1;
         border-left: 4px solid var(--accent); box-shadow: 0 1px 4px rgba(0,0,0,.06); }
  .kpi .val { font-size: 28px; font-weight: bold; color: var(--navy); }
  .kpi .lbl { font-size: 12px; color: #666; margin-top: 2px; }
  /* Sidebar + content */
  .layout { display: flex; gap: 24px; }
  .sidebar { width: 220px; flex-shrink: 0; }
  .sidebar ul { list-style: none; position: sticky; top: 16px; }
  .sidebar li a { display: block; padding: 8px 12px; border-radius: 6px; text-decoration: none;
                  color: var(--navy); font-size: 13px; margin-bottom: 4px; }
  .sidebar li a:hover { background: var(--light); }
  .content { flex: 1; min-width: 0; }
  /* Table cards */
  .table-card { background: white; border-radius: 10px; padding: 24px;
                margin-bottom: 28px; box-shadow: 0 1px 6px rgba(0,0,0,.07); }
  .table-header { display: flex; align-items: center; gap: 12px; margin-bottom: 12px; }
  .table-name { font-size: 20px; font-weight: bold; color: var(--navy); }
  .badge { padding: 3px 10px; border-radius: 12px; font-size: 11px; font-weight: bold; }
  .badge-rows { background: var(--light); color: var(--accent); }
  .table-desc { color: #444; margin-bottom: 10px; line-height: 1.6; }
  .purpose { font-style: italic; color: #555; margin-bottom: 16px; font-size: 13px; }
  /* Tags row */
  .tags { display: flex; flex-wrap: wrap; gap: 8px; margin-bottom: 16px; }
  .tag { padding: 3px 10px; border-radius: 12px; font-size: 11px; }
  .tag-fk    { background: #E8F4FD; color: #1a7bb9; border: 1px solid #bee3f8; }
  .tag-ref   { background: #EDF7ED; color: #276827; border: 1px solid #b8ddb8; }
  /* Columns table */
  .col-table { width: 100%; border-collapse: collapse; font-size: 13px; margin-bottom: 16px; }
  .col-table th { background: var(--light); color: var(--navy); padding: 8px 12px;
                  text-align: left; font-size: 12px; border-bottom: 2px solid #D0D6E0; }
  .col-table td { padding: 8px 12px; border-bottom: 1px solid #EEF0F4; vertical-align: top; }
  .col-table tr:hover td { background: #FAFBFC; }
  .pk-badge  { display: inline-block; padding: 1px 6px; border-radius: 4px; font-size: 10px;
               font-weight: bold; background: #FFF3CD; color: #856404; }
  .fk-badge  { display: inline-block; padding: 1px 6px; border-radius: 4px; font-size: 10px;
               font-weight: bold; background: #E8F4FD; color: #1a7bb9; }
  .null-high { color: #dc3545; font-weight: bold; }
  .null-ok   { color: #28a745; }
  /* Example query */
  .query-block { background: #1E2A3A; color: #A8D8A8; border-radius: 8px; padding: 14px 18px;
                 font-family: monospace; font-size: 12px; white-space: pre-wrap;
                 overflow-x: auto; margin-bottom: 16px; }
  /* Warnings */
  .warnings { background: var(--warn); border: 1px solid var(--warn-border); border-radius: 6px;
              padding: 12px 16px; margin-bottom: 12px; }
  .warnings h4 { color: #856404; font-size: 12px; margin-bottom: 6px; }
  .warnings li { font-size: 12px; color: #533f03; margin-left: 16px; }
  /* DDL toggle */
  details { margin-top: 8px; }
  summary { cursor: pointer; font-size: 12px; color: var(--accent); user-select: none; }
  pre.ddl { background: var(--light); padding: 12px; border-radius: 6px; font-size: 11px;
            overflow-x: auto; margin-top: 8px; white-space: pre-wrap; }
  /* Search */
  #search { width: 100%; padding: 10px 14px; border: 1px solid #D0D6E0; border-radius: 6px;
            font-size: 14px; margin-bottom: 20px; outline: none; }
  #search:focus { border-color: var(--accent); box-shadow: 0 0 0 3px rgba(46,117,182,.15); }
  .hidden { display: none; }
</style>
</head>
<body>

<header>
  <h1>📖 Data Catalog — {{ catalog.database_name }}</h1>
  <p>Generated {{ catalog.generated_at }} &nbsp;·&nbsp; AI-powered descriptions via Ollama (llama3.2) &nbsp;·&nbsp; Local, zero-cost</p>
</header>

<div class="container">
  <!-- KPIs -->
  <div class="kpi-row">
    <div class="kpi"><div class="val">{{ catalog.table_count }}</div><div class="lbl">Tables</div></div>
    <div class="kpi"><div class="val">{{ "{:,}".format(catalog.total_rows) }}</div><div class="lbl">Total Rows</div></div>
    <div class="kpi"><div class="val">{{ catalog.tables | sum(attribute='column_count') }}</div><div class="lbl">Total Columns</div></div>
    <div class="kpi"><div class="val">{{ catalog.tables | selectattr('quality_warnings') | list | length }}</div><div class="lbl">Tables with Warnings</div></div>
  </div>

  <input type="text" id="search" placeholder="🔍 Search tables and columns..." oninput="filterTables(this.value)"/>

  <div class="layout">
    <!-- Sidebar nav -->
    <div class="sidebar">
      <ul>
        {% for table in catalog.tables %}
        <li><a href="#{{ table.name }}">{{ table.name }}</a></li>
        {% endfor %}
      </ul>
    </div>

    <!-- Table cards -->
    <div class="content">
      {% for table in catalog.tables %}
      <div class="table-card" id="{{ table.name }}" data-searchtext="{{ table.name }} {{ table.description }} {% for c in table.columns %}{{ c.name }} {% endfor %}">

        <div class="table-header">
          <span class="table-name">{{ table.name }}</span>
          <span class="badge badge-rows">{{ "{:,}".format(table.row_count) }} rows</span>
          <span class="badge badge-rows">{{ table.column_count }} cols</span>
        </div>

        <p class="table-desc">{{ table.description }}</p>
        <p class="purpose">💡 {{ table.purpose }}</p>

        {% if table.foreign_keys or table.referenced_by %}
        <div class="tags">
          {% for fk in table.foreign_keys %}
          <span class="tag tag-fk">🔗 → {{ fk.to_table }}.{{ fk.to_column }}</span>
          {% endfor %}
          {% for ref in table.referenced_by %}
          <span class="tag tag-ref">← referenced by {{ ref }}</span>
          {% endfor %}
        </div>
        {% endif %}

        {% if table.quality_warnings %}
        <div class="warnings">
          <h4>⚠️ Data Quality Warnings</h4>
          <ul>{% for w in table.quality_warnings %}<li>{{ w }}</li>{% endfor %}</ul>
        </div>
        {% endif %}

        <!-- Column table -->
        <table class="col-table">
          <thead>
            <tr>
              <th>Column</th><th>Type</th><th>Nullable</th>
              <th>Null %</th><th>Distinct</th><th>Min / Max</th>
              <th>Sample Values</th><th>Description</th>
            </tr>
          </thead>
          <tbody>
          {% for col in table.columns %}
          <tr>
            <td>
              <strong>{{ col.name }}</strong>
              {% if col.is_primary_key %}<br/><span class="pk-badge">PK</span>{% endif %}
              {% if col.foreign_key %}<br/><span class="fk-badge">FK → {{ col.foreign_key.to_table }}</span>{% endif %}
            </td>
            <td><code>{{ col.data_type }}</code></td>
            <td>{{ "Yes" if col.nullable else "No" }}</td>
            <td class="{{ 'null-high' if col.is_high_null else 'null-ok' }}">{{ col.null_pct }}%</td>
            <td>{{ "{:,}".format(col.distinct_count) }}<br/><small style="color:#888">{{ col.cardinality_pct }}%</small></td>
            <td>
              {% if col.min_value is not none %}
                <small>{{ col.min_value }}<br/>{{ col.max_value }}</small>
              {% else %}—{% endif %}
            </td>
            <td><small>{{ col.sample_values[:3] | join(", ") if col.sample_values else "—" }}</small></td>
            <td>{{ col.description }}</td>
          </tr>
          {% endfor %}
          </tbody>
        </table>

        <!-- Example query -->
        <div class="query-block">{{ table.example_query }}</div>

        <!-- DDL -->
        <details>
          <summary>View CREATE TABLE DDL</summary>
          <pre class="ddl">{{ table.ddl }}</pre>
        </details>

      </div>
      {% endfor %}
    </div>
  </div>
</div>

<script>
function filterTables(query) {
  const q = query.toLowerCase();
  document.querySelectorAll('.table-card').forEach(card => {
    const text = card.dataset.searchtext.toLowerCase();
    card.classList.toggle('hidden', q.length > 0 && !text.includes(q));
  });
}
</script>
</body>
</html>
